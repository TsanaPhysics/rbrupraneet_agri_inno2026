    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# เพิ่มเซลล์สมองเทียม 128 เซลล์\n",
        "model.add(Dense(128, activation='relu'))\n",
        "# ชั้นส่งออก (Output) ตามจำนวน 3 คลาสด้วยแกนคณิตศาสตร์ Softmax\n",
        "model.add(Dense(3, activation='softmax'))\n"
      ]
    }
