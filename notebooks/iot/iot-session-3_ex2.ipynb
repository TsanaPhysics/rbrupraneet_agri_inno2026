      "source": [
        "# เซ็นเซอร์สภาพแวดล้อม (I2C Sensors)\n",
        "## อ่านค่าอุณหภูมิดิจิทัล (DHT)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "import dht\n",
        "\n",
        "sensor_th = dht.DHT22(Pin(15))\n",
        "sensor_th.measure() # สั่งให้ชิปทำงาน 1 รอบ\n",
        "\n",
        "temp = sensor_th.temperature()\n",
        "humid = sensor_th.humidity()\n",
        "print(f'🌡️ อากาศ: {temp}°C | 💦 ความชื้นลม: {humid}%')\n"
      ]
    }
  ],
