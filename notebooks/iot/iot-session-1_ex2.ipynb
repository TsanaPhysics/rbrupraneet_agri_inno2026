      "source": [
        "# สถาปัตยกรรม ESP32 (GPIO)\n",
        "## รับค่าสัญญาณ (Digital Input)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# จำลองการรับสัญญาณจากสวิตซ์หรือเซ็นเซอร์ใบพัดน้ำ\n",
        "button = Pin(0, Pin.IN, Pin.PULL_UP)\n",
        "\n",
        "if button.value() == 0:\n",
        "    print('🚨 มีการกดปุ่มฉุกเฉินปิดวาล์วน้ำ!')\n",
        "else:\n",
        "    print('✅ ระบบทำงานตามปกติ')\n"
      ]
    }
  ],
