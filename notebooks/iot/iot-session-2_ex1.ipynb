        "# สัญญาณแอนะล็อกและดิจิทัล (A/D)\n",
        "## ตั้งโปรแกรมช่องอ่าน Analog (ADC)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "from machine import ADC\n",
        "\n",
        "# เปิดใช้งานวงจรแปลงสัญญาณที่ขา 34\n",
        "soil_sensor = ADC(Pin(34))\n",
        "soil_sensor.atten(ADC.ATTN_11DB) # ปรับจูนให้รองรับไฟสูงสุด 3.3V\n",
        "print('พอร์ต ADC ขา 34 พร้อมรับสัญญาณธรรมชาติ...')\n"
      ]
    }
  ],
