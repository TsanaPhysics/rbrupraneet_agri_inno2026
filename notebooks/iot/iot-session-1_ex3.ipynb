      "source": [
        "from machine import PWM\n",
        "\n",
        "# ใช้ Pulse Width Modulation เพื่อหรี่แสง\n",
        "light = PWM(Pin(4), freq=1000)\n",
        "light.duty(512) # ปรับความสว่างที่ 50% (0-1023)\n",
        "print('เปิดไฟความสว่าง 50% แล้ว')\n"
      ]
