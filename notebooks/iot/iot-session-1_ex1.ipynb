      "source": [
        "# สถาปัตยกรรม ESP32 (GPIO)\n",
        "## Blink: ใจเต้นจังหวะแรก"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "from machine import Pin\n",
        "import time\n",
        "\n",
        "# กำหนดขา 2 เป็นขาออกไปยังหลอดไฟ LED บนบอร์ด\n",
        "led = Pin(2, Pin.OUT)\n",
        "\n",
        "while True:\n",
        "    led.value(not led.value()) # สลับสถานะ\n",
        "    time.sleep(0.5) # พักเครื่อง 0.5 วินาที\n"
      ]
    }
  ],
