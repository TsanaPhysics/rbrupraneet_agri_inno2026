        "# การทำงานซ้ำ (Loops in Agri)\n",
        "## Ex 5.3: While Loop จำลองการเติมน้ำ"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "tank_level = 0\n",
        "while tank_level < 3:\n",
        "    tank_level += 1\n",
        "    print(f\"กำลังสูบน้ำ... ระดับ {tank_level}/3\")\n",
        "print(\"ถังเต็ม!\")\n"
      ]
    }
