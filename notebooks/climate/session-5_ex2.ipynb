        "# การทำงานซ้ำ (Loops in Agri)\n",
        "## Ex 5.2: For Loop คำนวณค่ารวม"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "rain_week = [10, 0, 0, 5, 20, 0, 0] # มิลลิเมตร\n",
        "total = 0\n",
        "for rain in rain_week:\n",
        "    total += rain\n",
        "print(f\"ฝนรวม 7 วัน: {total} mm\")\n"
      ]
    }
